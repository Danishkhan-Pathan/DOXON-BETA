# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SERPER_API_KEY: Optional Serper.dev API key for Google-powered web searches.
# If configured, Doxon will use Serper.dev for fast real-time search results.
# If unconfigured, Doxon will automatically fall back to DuckDuckGo search.
SERPER_API_KEY=MY_SERPER_API_KEY
